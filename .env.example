# ============================================================
# AI Meeting Automation — Environment Variables Reference
# Copy this file to .env in each service directory and fill in.
# ============================================================


# ────────────────────────────────────────────────────────────
# [backend] Required
# ────────────────────────────────────────────────────────────

# Claude API (AI 분석)
ANTHROPIC_API_KEY=sk-ant-...

# Slack (알림 발송)
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=C0XXXXXXXXX

# ────────────────────────────────────────────────────────────
# [backend] STT
# ────────────────────────────────────────────────────────────

# "whisper-api" (기본, OpenAI 키 필요) | "local" (로컬 Whisper 모델)
STT_BACKEND=whisper-api
OPENAI_API_KEY=sk-...

# STT_BACKEND=local 일 때 사용할 Whisper 모델 크기
# tiny | base | small | medium | large (클수록 정확하지만 느림)
WHISPER_LOCAL_MODEL=base

# ────────────────────────────────────────────────────────────
# [backend] Integrations (선택)
# ────────────────────────────────────────────────────────────

# Jira
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=user@example.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=PROJ
JIRA_WEBHOOK_SECRET=

# Confluence
CONFLUENCE_BASE_URL=https://your-domain.atlassian.net
CONFLUENCE_EMAIL=user@example.com
CONFLUENCE_API_TOKEN=
CONFLUENCE_SPACE_KEY=DOC

# Slack 검색 (Retrieval)
SLACK_SEARCH_CHANNEL=general

# ────────────────────────────────────────────────────────────
# [backend] Security & Rate Limiting
# ────────────────────────────────────────────────────────────

# 백엔드 API 키 (빈 값이면 인증 비활성화)
BACKEND_API_KEY=

# 업로드 Rate Limit: IP당 WINDOW초 내 최대 LIMIT회
UPLOAD_RATE_LIMIT=10
UPLOAD_RATE_WINDOW=60

# ────────────────────────────────────────────────────────────
# [backend] Storage & Monitoring
# ────────────────────────────────────────────────────────────

STORAGE_DIR=./data/recordings

# 이상 탐지 임계치
ALERT_FAILURE_RATE=0.3
ALERT_MIN_CONFIDENCE=0.5

# ────────────────────────────────────────────────────────────
# [recording-page] Next.js
# ────────────────────────────────────────────────────────────

# 백엔드 업로드 URL (서버 사이드 프록시용 — 브라우저에 노출되지 않음)
UPLOAD_API_URL=http://localhost:8000
BACKEND_API_KEY=

# ────────────────────────────────────────────────────────────
# [slack-bot]
# ────────────────────────────────────────────────────────────

SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=

# 녹화 페이지 URL (Slack 버튼 링크)
RECORDING_PAGE_URL=http://localhost:3001

# Microsoft Graph API (캘린더 연동)
AZURE_CLIENT_ID=
AZURE_REDIRECT_URI=http://localhost:3000/auth/callback

PORT=3000
NODE_ENV=development
DEFAULT_TIMEZONE=Asia/Seoul
