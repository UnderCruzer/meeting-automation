# Local storage directory
STORAGE_DIR=./data/recordings

# API Key — set to a random secret to protect all endpoints (leave empty for local dev)
BACKEND_API_KEY=

# CORS — comma-separated origins
ALLOWED_ORIGINS=http://localhost:3001

# STT backend: "whisper-api" (default) | "local"
STT_BACKEND=whisper-api

# Required when STT_BACKEND=whisper-api
OPENAI_API_KEY=sk-...

# Required for AI Orchestrator (Claude API)
ANTHROPIC_API_KEY=sk-ant-...

# Local Whisper model size: tiny / base / small / medium / large
# Larger = more accurate but slower. "base" is a good MVP default.
WHISPER_LOCAL_MODEL=base

# Bounded Retrieval — Jira (all required to enable Jira search)
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_PROJECT_KEY=PROJ
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=

# Bounded Retrieval — Confluence
CONFLUENCE_BASE_URL=https://yourorg.atlassian.net/wiki
CONFLUENCE_SPACE_KEY=SPACE
CONFLUENCE_EMAIL=your@email.com
CONFLUENCE_API_TOKEN=

# Bounded Retrieval — Slack (reuse SLACK_BOT_TOKEN from slack-bot)
SLACK_BOT_TOKEN=xoxb-...
SLACK_SEARCH_CHANNEL=general

# Review & Approval
SLACK_REVIEW_CHANNEL=meeting-reviews
CONFLUENCE_MEETING_PARENT_PAGE_ID=
SLACK_BRIEF_CHANNEL=general

# Timezone Scheduler (#18) — regional tz overrides (optional)
REGION_TZ_APAC=Asia/Seoul
REGION_TZ_EU=Europe/Paris
REGION_TZ_NA=America/New_York

# Regional Slack Delivery (#19) — per-region channels
SLACK_CHANNEL_APAC=meeting-brief-apac
SLACK_CHANNEL_EU=meeting-brief-eu
SLACK_CHANNEL_NA=meeting-brief-na

# Brief / Digest (#20) — scheduler settings
DIGEST_CHANNEL=meeting-digest
DIGEST_SUBSCRIBERS=          # comma-separated Slack user IDs (e.g. U12345,U67890)

# Follow-up Automation (#21)
JIRA_STAKEHOLDER_SLACK_IDS=  # comma-separated Slack user IDs to notify on Jira status change
JIRA_WEBHOOK_SECRET=         # shared secret for HMAC-SHA256 webhook signature verification

# Monitoring & Feedback (#22)
MONITOR_ALERT_CHANNEL=monitoring-alerts
ALERT_FAILURE_RATE=0.3       # failure rate threshold (0–1) for anomaly alert
ALERT_MIN_CONFIDENCE=0.5     # AI confidence threshold for anomaly alert

# Slack-bot — sentAlerts persistent store (#23)
ALERT_STORE_PATH=./data/sent_alerts.json

# Slack-bot — default timezone fallback (#24)
DEFAULT_TIMEZONE=Asia/Seoul
